{
    "user_id": "guest",
    "save_dir": "lightmem_output",
    "api_key": "YOUR_OPENAI_API_KEY",
    "base_url": "YOUR_OPENAI_API_BASE",
    "llm_model": "gpt-4o-mini",
    "llm_temperature": 0.1,
    "llm_max_tokens": 16000,
    "llm_top_p": 0.1,
    "pre_compress": true,
    "llmlingua_model_path": "microsoft/llmlingua-2-bert-base-multilingual-cased-meetingbank",
    "compress_rate": 0.8,
    "compress_target_token": -1,
    "topic_segment": true,
    "precomp_topic_shared": true,
    "messages_use": "user_only",
    "metadata_generate": true,
    "text_summary": true,
    "extraction_mode": "flat",
    "extract_threshold": 0.1,
    "embedding_provider": "huggingface",
    "embedding_model": "sentence-transformers/all-MiniLM-L6-v2",
    "embedding_dims": 384,
    "embedding_device": "cuda",
    "embedding_model_kwargs": {},
    "enable_summary": false,
    "summary_top_k": 5,
    "summary_time_window": 3600,
    "summary_top_k_seeds": 15,
    "summary_enable_cross_event": true,
    "summary_retrieval_scope": "global"
}
